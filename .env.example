# Copy to .env (gitignored) for local runs, or set these as Routine environment
# variables in claude.ai/code. NEVER commit real values.

# Kalshi API key ID (UUID from the Kalshi dashboard).
KALSHI_KEY_ID=

# Kalshi RSA private key, PEM format. For a single env var, the PEM newlines may be
# replaced with literal "\n" — config.py normalizes both forms.
KALSHI_PRIVATE_KEY=

# Optional: cap the heavier bootstrap (first) run to N markets. Unset = no cap.
# FIRST_RUN_MAX=10
